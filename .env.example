# ─── Lima Trade — Environment Variables ──────────────────────────────────────
# Copy this file to .env.local for local development.
# Set these in Vercel → Project → Settings → Environment Variables for production.
# NEVER commit .env.local to git.

# ── Deriv App Registration (NEW API — developers.deriv.com) ──────────────────
#
# Lima Trade uses the NEW Deriv API (2024+) with OAuth 2.0 + PKCE.
# Auth endpoint:  https://auth.deriv.com/oauth2/auth
# Token endpoint: https://auth.deriv.com/oauth2/token
# REST/WS base:   https://api.derivws.com
#
# To register your app:
#   1. Go to https://developers.deriv.com
#   2. Log in → register or find your app
#   3. Set the OAuth Redirect URL to:
#         https://YOUR-VERCEL-DOMAIN.vercel.app/callback
#      (local dev: http://localhost:3000/callback)
#   4. Select scopes: trade, account_manage
#   5. Save — copy the App ID shown in your app details
#
# NOTE: The App ID on the new Deriv API is an alphanumeric string
#       (e.g. "33EsxEGxJdpnIFRvtiSpY") — not an integer.
#
DERIV_CLIENT_ID=your_app_id_here

# ── Redirect URI (REQUIRED) ───────────────────────────────────────────────────
# Must exactly match the OAuth Redirect URL registered above.
# No trailing slash. Visit /api/auth/debug to confirm the exact value.
#
NEXT_PUBLIC_REDIRECT_URI=https://your-vercel-domain.vercel.app/callback

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-vercel-domain.vercel.app

# ── Session Secret ────────────────────────────────────────────────────────────
# Encrypts the iron-session cookie. Must be at least 32 characters.
# Generate one: https://generate-secret.vercel.app/32
# KEEP SECRET — changing this invalidates all active sessions.
SESSION_SECRET=replace_this_with_a_random_32_plus_character_string_keep_it_secret
